# ============================================================
#  Discord Chatbot – Konfiguration
#  Kopiere diese Datei als ".env" und trage deine Werte ein.
# ============================================================

# --- Pflichtfelder ---

# Discord Bot Token (https://discord.com/developers/applications)
DISCORD_TOKEN=dein-discord-bot-token-hier

# Anthropic API Key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# --- Bot-Persönlichkeit ---

# Name des Bots (wird im System-Prompt verwendet)
BOT_NAME=Alex

# Eigener System-Prompt (optional – überschreibt den Standard)
# SYSTEM_PROMPT=Du bist Alex, ein sarkastischer Typ der immer seinen Senf dazugibt...

# --- Kanal-Konfiguration ---

# Kanäle werden über CHANNEL_<name>=<id> definiert.
# Optional kann jeder Kanal einen eigenen System-Prompt und ein eigenes Modell bekommen.
# Kanal-ID findest du: Discord → Rechtsklick auf Kanal → ID kopieren (Entwicklermodus nötig)
#
# Beispiel:
CHANNEL_general=123456789012345678
CHANNEL_memes=987654321098765432
# CHANNEL_memes_PROMPT=Du bist ein Witzbold. Kurze, lustige Antworten. Immer mit einem Augenzwinkern.
# CHANNEL_memes_MODEL=claude-haiku-4-5-20251001
# CHANNEL_memes_COOLDOWN=30
#
# Ohne CHANNEL_*-Einträge kannst du auch die alte Schreibweise verwenden (kein Name, kein Override):
# ACTIVE_CHANNEL_IDS=123456789012345678,987654321098765432
#
# Leer lassen = Bot ist in ALLEN Kanälen aktiv (nicht empfohlen).

# --- Verhalten ---

# Rollen die alle Memories/Reminders anderer Nutzer sehen und löschen dürfen
MOD_ROLE_NAMES=Admin,Mod,Moderator

# Zeitzone für Erinnerungen und Tagesrückblick
TIMEZONE=Europe/Berlin

# Tagesrückblick – Uhrzeit in lokaler Zeit (TIMEZONE)
DIGEST_ENABLED=true
DIGEST_HOUR=23
DIGEST_MINUTE=0

# Mindest-Pause zwischen zwei unaufgeforderten Antworten (in Sekunden)
# Der Bot entscheidet selbst ob er antwortet – dieser Wert verhindert nur Spam
COOLDOWN_SECONDS=120

# Anzahl vergangener Nachrichten die als Kontext mitgeschickt werden
CONTEXT_WINDOW=20

# Wie viele Nachrichten der Zusammenfassung (@Bot fass zusammen) berücksichtigt werden
SUMMARY_WINDOW=30

# Wahrscheinlichkeit mit der der Bot auf fremde Nachrichten mit einem Emoji reagiert (0.0–1.0)
EMOJI_REACTION_RATE=0.20

# Claude Modell (claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001)
# Haiku ist am günstigsten, Opus am klügsten
CLAUDE_MODEL=claude-sonnet-4-6
