# ============================================================
#  Discord Chatbot – Configuration
#  Copy this file as ".env" and fill in your values.
# ============================================================

# --- Required fields ---

# Discord Bot Token (https://discord.com/developers/applications)
DISCORD_TOKEN=dein-discord-bot-token-hier

# Anthropic API Key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# --- Bot personality ---

# Name of the bot (used in the system prompt)
BOT_NAME=Alex

# Custom system prompt (optional — overrides the default)
# SYSTEM_PROMPT=Du bist Alex, ein sarkastischer Typ der immer seinen Senf dazugibt...

# MAIN_SYSTEM_PROMPT=Du bist Alex, du hängst hier immer rum und mischst dich ein wenn was Interessantes passiert...

# --- Model slots ---
# Four named slots. Any slot can be assigned to any tier below.
# Set LOCAL_MODEL + OLLAMA_BASE_URL to enable local LLM support.

# OLLAMA_BASE_URL=http://192.168.1.100:11434
# LOCAL_MODEL=llama3.1:8b-instruct-q4_0

CHEAP_MODEL=claude-haiku-4-5-20251001
NORMAL_MODEL=claude-sonnet-4-6
EXPENSIVE_MODEL=claude-sonnet-4-6
# EXPENSIVE_MODEL=claude-opus-4-7

# --- Tier assignments ---
# Which model slot each feature uses: local | cheap | normal | expensive

# Responses in main channels
MAIN_TIER=expensive
# Responses in mention-only channels
MENTION_TIER=normal
# Intent classification
CLASSIFY_TIER=cheap
# Emoji reactions
EMOJI_TIER=cheap
# Memory relevance filtering
MEMORY_FILTER_TIER=cheap
# Prompt-mode reminder responses
REMINDER_TIER=normal
# Proactive conversation starters
PROACTIVE_TIER=expensive
# Daily digest summary
DIGEST_SUMMARY_TIER=expensive
# Daily digest fact extraction
DIGEST_FACTS_TIER=normal

# --- Channel configuration ---

# Main channels: the bot joins conversations autonomously here.
# Comma-separated channel IDs. Channel ID: Discord → right-click channel → Copy ID (requires Developer Mode).
# In all other channels the bot only responds to @mentions.
MAIN_CHANNEL_IDS=123456789012345678,987654321098765432

# --- Behaviour ---

# Roles that can view and delete other users' memories/reminders
MOD_ROLE_NAMES=Admin,Mod,Moderator

# Timezone for reminders and daily digest
TIMEZONE=Europe/Berlin

# Daily digest — time in local time (TIMEZONE)
DIGEST_ENABLED=true
DIGEST_HOUR=23
DIGEST_MINUTE=0

# Minimum pause between two unsolicited responses in main channels (in seconds)
COOLDOWN_SECONDS=120

# Number of past messages sent as context
CONTEXT_WINDOW=20

# How many messages the summary command (@Bot summarise) considers
SUMMARY_WINDOW=30

# Probability that the bot reacts to a foreign message with an emoji (0.0–1.0)
EMOJI_REACTION_RATE=0.20

# Minimum wait time in hours before the same flavor memory entry is injected again
FLAVOR_COOLDOWN_HOURS=6

# Proactive conversation starter — bot chimes in when the channel is quiet
PROACTIVE_ENABLED=true
# Earliest hour (local time) for proactive messages
PROACTIVE_HOUR_START=15
# Latest hour
PROACTIVE_HOUR_END=23
# How long the channel must be quiet before the bot steps in
PROACTIVE_SILENCE_MINUTES=45
# Minimum interval between two proactive messages per channel
PROACTIVE_COOLDOWN_HOURS=4
# How often (in minutes) the bot checks whether to step in
PROACTIVE_CHECK_MINUTES=15

# --- Storage & logging ---

# Directory for persistent data (memories, quotes, reminders)
DATA_DIR=/app/data

# Directory for log files (rotated daily, 30-day retention)
LOG_DIR=/app/logs

# --- Logging ---

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# DEBUG produces detailed output for fetch, intent classification, memory matching, etc.
# LOG_LEVEL=DEBUG
