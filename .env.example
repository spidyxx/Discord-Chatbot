# ============================================================
#  Discord Chatbot – Konfiguration
#  Kopiere diese Datei als ".env" und trage deine Werte ein.
# ============================================================

# --- Pflichtfelder ---

# Discord Bot Token (https://discord.com/developers/applications)
DISCORD_TOKEN=dein-discord-bot-token-hier

# Anthropic API Key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# --- Bot-Persönlichkeit ---

# Name des Bots (wird im System-Prompt verwendet)
BOT_NAME=Alex

# Eigener System-Prompt (optional – überschreibt den Standard)
# SYSTEM_PROMPT=Du bist Alex, ein sarkastischer Typ der immer seinen Senf dazugibt...

# Modell und System-Prompt für Hauptkanäle (aktive Teilnahme, antwortet von selbst)
# claude-opus-4-6 = klügster, claude-sonnet-4-6 = ausgewogen, claude-haiku-4-5-20251001 = günstigster
MAIN_MODEL=claude-sonnet-4-6
# MAIN_SYSTEM_PROMPT=Du bist Alex, du hängst hier immer rum und mischst dich ein wenn was Interessantes passiert...

# Modell und System-Prompt für alle anderen Kanäle (nur auf @Mention)
CLAUDE_MODEL=claude-haiku-4-5-20251001
# SYSTEM_PROMPT=Du bist Alex, knapp und direkt, nur auf Nachfrage...

# Günstiges Modell für Intent-Klassifizierung und Memory-Filterung
CHEAP_MODEL=claude-haiku-4-5-20251001

# --- Kanal-Konfiguration ---

# Hauptkanäle: Hier mischt sich der Bot von selbst in Gespräche ein.
# Kommagetrennte Kanal-IDs. Kanal-ID: Discord → Rechtsklick auf Kanal → ID kopieren (Entwicklermodus nötig).
# In allen anderen Kanälen antwortet der Bot nur auf @Mentions.
MAIN_CHANNEL_IDS=123456789012345678,987654321098765432

# --- Verhalten ---

# Rollen die alle Memories/Reminders anderer Nutzer sehen und löschen dürfen
MOD_ROLE_NAMES=Admin,Mod,Moderator

# Zeitzone für Erinnerungen und Tagesrückblick
TIMEZONE=Europe/Berlin

# Tagesrückblick – Uhrzeit in lokaler Zeit (TIMEZONE)
DIGEST_ENABLED=true
DIGEST_HOUR=23
DIGEST_MINUTE=0

# Mindest-Pause zwischen zwei unaufgeforderten Antworten in Hauptkanälen (in Sekunden)
COOLDOWN_SECONDS=120

# Anzahl vergangener Nachrichten die als Kontext mitgeschickt werden
CONTEXT_WINDOW=20

# Wie viele Nachrichten der Zusammenfassung (@Bot fass zusammen) berücksichtigt werden
SUMMARY_WINDOW=30

# Wahrscheinlichkeit mit der der Bot auf fremde Nachrichten mit einem Emoji reagiert (0.0–1.0)
EMOJI_REACTION_RATE=0.20

# Mindestwartezeit in Stunden bevor derselbe Flavor-Memory-Eintrag erneut injiziert wird
FLAVOR_COOLDOWN_HOURS=6

# Proaktive Gesprächseröffnung – Bot greift selbst ein wenn der Kanal still ist
PROACTIVE_ENABLED=true
PROACTIVE_HOUR_START=15       # Früheste Stunde (Lokalzeit) für proaktive Nachrichten
PROACTIVE_HOUR_END=23         # Späteste Stunde
PROACTIVE_SILENCE_MINUTES=45  # Wie lange muss der Kanal still sein bevor der Bot eingreift
PROACTIVE_COOLDOWN_HOURS=4    # Mindestabstand zwischen zwei proaktiven Nachrichten pro Kanal
PROACTIVE_CHECK_MINUTES=15    # Wie oft (in Minuten) der Bot prüft ob er eingreifen soll

# --- Speicher & Logging ---

# Verzeichnis für persistente Daten (Memories, Quotes, Reminders)
DATA_DIR=/app/data

# Verzeichnis für Log-Dateien (täglich rotiert, 30 Tage Aufbewahrung)
LOG_DIR=/app/logs

# --- Logging ---

# Log-Level: DEBUG, INFO, WARNING, ERROR (Standard: INFO)
# DEBUG liefert detaillierte Ausgaben zu Fetch, Intent-Klassifizierung, Memory-Matching usw.
# LOG_LEVEL=DEBUG
